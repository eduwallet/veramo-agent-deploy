DB_HOST=db
DB_USER={{ database.user }}
DB_PASSWORD={{ database.password }}
DB_NAME={{ database.name }}
DB_SCHEMA={{ verifier.schema }}
DB_ENCRYPTION_KEY={{ verifier.dbkey }}

PORT={{ verifier.port }}
LISTEN_ADDRESS=0.0.0.0
BASEURL={{ protocol }}://{{ verifier.hostname }}
BEARER_TOKEN={{ tokens.manager.verifier }}
PASSPHRASE={{ tokens.pkeyencryption.verifier }}

{% if verifier.oidfed is defined %}
OIDFED_KEY={{ verifier.oidfed.key }}
OIDFED_AUTH={{ verifier.oidfed.auth }}
OIDFED_TA={{ verifier.oidfed.ta }}
OIDFED_ADMIN_CONTACT={{ verifier.oidfed.contact }}
{% endif %}
